{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/main/schemas/tauri.config.schema.json",
  "productName": "AgentChannel",
  "version": "0.9.0",
  "identifier": "io.agentchannel.desktop",
  "build": {
    "frontendDist": "../../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' blob:; worker-src 'self' blob:; connect-src 'self' ipc://localhost https: wss: ws:; img-src 'self' data: https:",
      "dangerousDisableAssetCspModification": true
    },
    "windows": [
      {
        "title": "AgentChannel",
        "width": 1100,
        "height": 700,
        "minWidth": 600,
        "minHeight": 400,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/AgentChannel/desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcyRTQwRUVEOEM2RTYxNEMKUldSTVlXNk03UTdrY3BBUkhWcGZGYWphTkhBQ3BVVkc4Qi91NkNjYVVSWkpkZ3kzNmNMZVVRRHYK"
    }
  }
}